# ---------------------------------------------------------------------------
# Yagura Enterprise — environment variables
# ---------------------------------------------------------------------------
# Copy to `.env` and fill in. `.env` is gitignored by default.

# --- LLM providers ---------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
YAGURA_PLANNER_MODEL=claude-sonnet-4-20250514
YAGURA_EXECUTOR_MODEL=qwen2.5:7b
YAGURA_FALLBACK_MODEL=claude-sonnet-4-20250514
OLLAMA_HOST=http://ollama:11434

# --- Datadog (audit logger) -----------------------------------------------
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SERVICE=yagura-enterprise
DATADOG_ENV=production
DATADOG_SITE=datadoghq.com

# --- OAuth2 (auth provider) ------------------------------------------------
# Example for Azure AD:
#   OAUTH_ISSUER=https://login.microsoftonline.com/{tenant}/v2.0
# Example for Google:
#   OAUTH_ISSUER=https://accounts.google.com
OAUTH_ISSUER=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_SCOPES=openid profile email
OAUTH_AUDIENCE=

# --- PostgreSQL (state store) ---------------------------------------------
POSTGRES_USER=yagura
POSTGRES_PASSWORD=yagura
POSTGRES_DB=yagura
POSTGRES_URL=postgresql://yagura:yagura@postgres:5432/yagura
POSTGRES_TABLE=yagura_sessions

# --- Security policy (RAG endpoint) ---------------------------------------
# POST-ed with {"query", "filter", "top_k"}. Must return {"hits": [...]}.
YAGURA_RAG_ENDPOINT=http://localhost:8080/search

# --- Confidential-data routing --------------------------------------------
YAGURA_CONFIDENTIAL_PATTERNS=/confidential/,/機密/,/internal-only/

# --- Concurrency / scaling -------------------------------------------------
YAGURA_MAX_SESSIONS=50

# --- CORS ------------------------------------------------------------------
# Comma-separated origins allowed by the FastAPI CORS middleware.
# Default when unset: http://localhost:3000,http://localhost:8080
YAGURA_CORS_ORIGINS=https://app.example.com,https://admin.example.com
